<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         SCHOOL STUDENT — FORM VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_school_student_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form class="o_school_cafeteria_student_form" string="Student">
                <header>
                    <button name="action_print_card"
                            string="Print ID Card"
                            type="object"
                            class="btn-secondary"
                            icon="fa-print"/>
                    <button name="%(school_cafeteria.action_recharge_wizard)d"
                            string="Quick Recharge"
                            type="action"
                            class="btn-success"
                            icon="fa-plus-circle"/>
                            
                    <button name="action_replace_card"
                            string="Replace Lost Card"
                            type="object"
                            class="btn-warning"
                            icon="fa-refresh"
                            confirm="Replace the student's card? The old barcode will stop working immediately."/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transactions"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-history"
                                invisible="not id">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="balance" widget="monetary"/>
                                </span>
                                <span class="o_stat_text">Balance</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" placeholder="Student Full Name"/></h1>
                    </div>

                    <group>
                        <group string="Academic">
                            <field name="grade"/>
                            <field name="section"/>
                            <field name="academic_year"/>
                            <field name="active" widget="toggle_button"/>
                        </group>
                        <group string="Card">
                            <field name="card_active" widget="toggle_button"/>
                            <field name="photo" widget="image"/>
                            <field name="card_uid" placeholder="Card UID / Barcode"/>
                            <field name="student_code" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- TAB: Parent & Notifications -->
                        <page string="Parent &amp; Notifications" name="parent">
                            <group>
                                <group string="Parent / Guardian">
                                    <field name="parent_id"
                                           options="{'no_create_edit': True}"
                                           placeholder="Search existing contacts..."/>
                                    <field name="parent_phone" readonly="1"/>
                                </group>
                                <group string="Notification Settings">
                                    <field name="notification_channel" widget="radio"/>
                                    <field name="whatsapp_opt_in"
                                           invisible="notification_channel != 'whatsapp'"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB: Meal Plan -->
                        <page string="Meal Plan" name="plan">
                            <group>
                                <group string="Active Plan">
                                    <field name="plan_id" options="{'no_create_edit': True}"/>
                                    <field name="plan_expiry"/>
                                    <field name="plan_active" readonly="1" widget="toggle_button"/>
                                </group>
                                <group string="Plan Summary"
                                       invisible="plan_id == False">
                                    <field name="plan_id" string=" "
                                           widget="many2one_avatar" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB: Spending Rules -->
                        <page string="Spending Rules" name="restrictions">
                            <group>
                                <group string="Limits">
                                    <field name="daily_limit"
                                           help="0 = no limit. Plan limit overrides this if plan is active."/>
                                    <field name="purchase_time_from"/>
                                    <field name="purchase_time_to"/>
                                </group>
                                <group string="Product Restrictions">
                                    <field name="forbidden_product_ids" widget="many2many_tags"
                                           options="{'no_create_edit': True}"/>
                                    <field name="allowed_category_ids" widget="many2many_tags"
                                           options="{'no_create_edit': True}"
                                           help="Leave empty = all categories allowed"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB: Wallet History -->
                        <page string="Transaction History" name="wallet">
                            <field name="wallet_id" readonly="1">
                                <form>
                                    <field name="transaction_ids" readonly="1">
                                        <list string="Transactions" decoration-success="transaction_type == 'credit'"
                                              decoration-danger="transaction_type == 'purchase'"
                                              decoration-info="transaction_type == 'refund'">
                                            <field name="date"/>
                                            <field name="transaction_type" string="Type"/>
                                            <field name="amount" string="Amount (EGP)"/>
                                            <field name="reference"/>
                                            <field name="cashier_id"/>
                                            <field name="state"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         SCHOOL STUDENT — LIST VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_school_student_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list string="Students"
                  decoration-warning="balance &lt; 30"
                  decoration-danger="balance &lt;= 0">
                <field name="photo" widget="image" options="{'size': [32, 32]}"/>
                <field name="name"/>
                <field name="student_code"/>
                <field name="grade"/>
                <field name="section"/>
                <field name="plan_id"/>
                <field name="balance" string="Balance (EGP)" sum="Total Balance"/>
                <field name="today_spent" string="Today (EGP)"/>
                <field name="card_active" widget="toggle_button" optional="show"/>
                <field name="plan_active" widget="toggle_button" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         SCHOOL STUDENT — SEARCH VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_school_student_search" model="ir.ui.view">
        <field name="name">school.student.search</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="name" string="Name or Code"
                       filter_domain="['|', ('name', 'ilike', self), ('student_code', 'ilike', self)]"/>
                <field name="grade"/>
                <field name="parent_id"/>
                <filter string="Low Balance (≤ 30 EGP)" name="low_balance"
                        domain="[('balance', '&lt;=', 30), ('balance', '&gt;', 0)]"/>
                <filter string="Zero Balance" name="zero_balance"
                        domain="[('balance', '&lt;=', 0)]"/>
                <filter string="Has Active Plan" name="has_plan"
                        domain="[('plan_active', '=', True)]"/>
                <filter string="Card Disabled" name="card_disabled"
                        domain="[('card_active', '=', False)]"/>
                <separator/>
                <group>
                    <filter string="Grade" name="by_grade" context="{'group_by': 'grade'}"/>
                    <filter string="Meal Plan" name="by_plan" context="{'group_by': 'plan_id'}"/>
                    <filter string="Section" name="by_section" context="{'group_by': 'section'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════════════════ -->
    <record id="action_school_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_school_student_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first student!
            </p>
            <p>
                Create student profiles, print their barcode cards, and manage cafeteria balances.
            </p>
        </field>
    </record>

</odoo>
